---
interface Props {
  title: string
}
const { title } = Astro.props
---

<meta charset='UTF-8' />
<title>{title}</title>
<meta name='viewport' content='width=device-width' />
<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
<link rel='icon' href='/favicon.ico' />
<meta name='generator' content={Astro.generator} />
